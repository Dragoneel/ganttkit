{
  "name": "@ganttkit/plugin-tree",
  "version": "0.1.2",
  "author": "dchar",
  "description": "Hierarchical rows with expand/collapse for GanttKit (rows-hook plugin).",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Dragoneel/ganttkit.git",
    "directory": "packages/plugin-tree"
  },
  "type": "module",
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "sideEffects": false,
  "files": [
    "dist"
  ],
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "peerDependencies": {
    "@ganttkit/core": "workspace:*"
  },
  "devDependencies": {
    "@ganttkit/core": "workspace:*",
    "tsup": "^8.3.5",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}