{
  "name": "@ganttkit/plugin-tooltip",
  "version": "0.1.0",
  "description": "Hover tooltip card for GanttKit tasks (UI-slot plugin).",
  "type": "module",
  "license": "MIT",
  "sideEffects": false,
  "files": ["dist"],
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --passWithNoTests"
  },
  "peerDependencies": {
    "@ganttkit/core": "workspace:*"
  },
  "devDependencies": {
    "@ganttkit/core": "workspace:*",
    "tsup": "^8.3.5",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
